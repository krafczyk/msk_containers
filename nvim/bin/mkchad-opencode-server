#!/usr/bin/env bash

# Enter the active Neovim image through the standard container-tools launcher,
# then delegate to the in-image lifecycle command. Keep diagnostics on stderr:
# --json is a strict protocol consumed by the editor adapter.
set -euo pipefail

program=${0##*/}
script_dir=$(dirname "$(realpath "$0")")
image_command="$script_dir/mkchad-opencode-server-image"
bootstrap="$script_dir/mkchad-container-bootstrap"
config_home=${XDG_CONFIG_HOME:-"$HOME/.config"}
config_root="$config_home/mkchad"
runtime_dir=${XDG_RUNTIME_DIR:-"$HOME/.local/share/mkchad/tmp"}
cache_dir=${XDG_CACHE_HOME:-"$HOME/.local/cache"}
npm_base="$HOME/.local/share/msk_containers/npm-global"
npm_container_base=/opt/msk/npm-global
opencode_config="$config_root/opencode.jsonc"

die() {
  printf '%s: %s\n' "$program" "$*" >&2
  exit "${2:-1}"
}

[[ -x $image_command ]] || die "in-image lifecycle command is missing or not executable: $image_command"
[[ -x $bootstrap ]] || die "container bootstrap is missing or not executable: $bootstrap"

container_signal=${SINGULARITY_CONTAINER:-${APPTAINER_CONTAINER:-}}
if [[ -n $container_signal && ( ${MKCHAD_NVIM_IMAGE:-} == 1 || ${container_signal##*/} == neovim.sif ) ]]; then
  # Compatibility for MkChad revisions that still call the public launcher.
  exec "$image_command" "$@"
fi

if command -v apptainer >/dev/null 2>&1; then
  runtime=apptainer
elif command -v singularity >/dev/null 2>&1; then
  runtime=singularity
else
  die "neither Apptainer nor SingularityCE is available"
fi
container_launcher="$script_dir/ct_exec.sh"
[[ -x $container_launcher ]] || die "container tools launcher is missing or not executable: $container_launcher"

container_dir=${NVIM_CONTAINER_DIR:-"$HOME/containers"}
image=${NVIM_CONT_LOCATION:-"$container_dir/neovim.sif"}
[[ -f $image ]] || die "active Neovim image is missing: $image"

mkdir -p -- "$runtime_dir" "$cache_dir" "$npm_base"

exec "$container_launcher" "--$runtime" \
  --ct-bind "$npm_base:$npm_container_base" \
  --ct-env "MKCHAD_NVIM_IMAGE=1" \
  --ct-env "NVIM_APPNAME=mkchad" \
  --ct-env "XDG_CONFIG_HOME=$config_home" \
  --ct-env "XDG_RUNTIME_DIR=$runtime_dir" \
  --ct-env "XDG_CACHE_HOME=$cache_dir" \
  --ct-env "MSK_NPM_GLOBAL_BASE=$npm_container_base" \
  --ct-env "OPENCODE_CONFIG=$opencode_config" \
  --ct-bootstrap "$bootstrap" \
  -- "$image" "$image_command" "$@"
