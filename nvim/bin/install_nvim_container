#!/usr/bin/env bash

set -euo pipefail

program=${0##*/}
install_dir=${NVIM_CONTAINER_DIR:-"$HOME/containers"}
keep=2
activate=1
force=0
dry_run=0
rollback=0
source_image=
stage=
link_stage=

usage() {
  cat <<EOF
Usage:
  $program [options] IMAGE
  $program [options] --rollback

Install and activate a transported Neovim SIF image. Managed image names use:

  neovim_VERSION_gGITREV_DIGEST_ARCH.sif

Raw build images named nvim_container_{x86,aarch64,ppc64le}.sif are assigned a
managed name automatically. VERSION comes from the image, GITREV from the HEAD
of the checkout containing the image, and DIGEST from the image's SHA-256.

Options:
  --install-dir PATH  Container directory (default: ~/containers)
  --keep NUMBER       Installed image slots to retain (default: 2)
  --no-activate       Install without changing neovim.sif
  --force             Replace a corrupt destination with the source image
  --dry-run           Validate and report without making changes
  --rollback          Swap neovim.sif and neovim.previous.sif
  -h, --help          Show this help

If IMAGE.sha256 exists, its first field must contain IMAGE's SHA-256 digest.
EOF
}

die() {
  printf '%s: %s\n' "$program" "$*" >&2
  exit 1
}

log() {
  printf '%s\n' "$*"
}

cleanup() {
  if [[ -n $stage && -e $stage ]]; then
    rm -f -- "$stage"
  fi
  if [[ -n $link_stage && -d $link_stage ]]; then
    rm -rf -- "$link_stage"
  fi
}
trap cleanup EXIT

normalize_arch() {
  case "$1" in
    x86 | x86_64 | amd64) printf '%s\n' x86_64 ;;
    aarch64 | arm64) printf '%s\n' aarch64 ;;
    ppc64le | ppc64el) printf '%s\n' ppc64le ;;
    *) printf '%s\n' "$1" ;;
  esac
}

is_managed_name() {
  [[ $1 =~ ^neovim_[0-9]+\.[0-9]+\.[0-9]+_g[0-9a-fA-F]{7,40}_[0-9a-fA-F]{8,64}_(x86|x86_64|aarch64|ppc64le)\.sif$ ]]
}

image_runtime() {
  if command -v apptainer >/dev/null 2>&1; then
    printf '%s\n' apptainer
  elif command -v singularity >/dev/null 2>&1; then
    printf '%s\n' singularity
  else
    die "neither Apptainer nor Singularity is installed"
  fi
}

image_version() {
  local image=$1
  local runtime output first_line

  runtime=$(image_runtime)
  if ! output=$("$runtime" exec "$image" nvim --version 2>&1); then
    printf '%s\n' "$output" >&2
    die "container validation failed: $image"
  fi
  first_line=${output%%$'\n'*}
  [[ $first_line == "NVIM v"* ]] || die "unexpected Neovim version output: $first_line"
  printf '%s\n' "${first_line#NVIM v}"
}

verify_image() {
  local image=$1
  local expected_version=${2:-}
  local actual_version

  actual_version=$(image_version "$image")
  if [[ -n $expected_version && $actual_version != "$expected_version" ]]; then
    die "image reports NVIM v${actual_version}, expected Neovim v${expected_version}"
  fi
}

safe_link_target() {
  local link=$1
  local raw resolved

  [[ -L $link ]] || return 1
  raw=$(readlink -- "$link")
  if [[ $raw == /* ]]; then
    resolved=$(realpath -m -- "$raw")
  else
    resolved=$(realpath -m -- "${link%/*}/$raw")
  fi
  [[ ${resolved%/*} == "$install_dir" && -f $resolved ]] || return 1
  printf '%s\n' "${resolved##*/}"
}

replace_link() {
  local target=$1
  local link=$2
  local temporary

  link_stage=$(mktemp -d "${install_dir}/.link.XXXXXX")
  temporary="${link_stage}/link"
  ln -s -- "$target" "$temporary"
  mv -fT -- "$temporary" "$link"
  rmdir -- "$link_stage"
  link_stage=
}

check_link_type() {
  local link=$1
  if [[ -e $link && ! -L $link ]]; then
    die "refusing to replace non-symlink: $link"
  fi
}

check_link_target() {
  local link=$1
  if [[ -L $link ]]; then
    safe_link_target "$link" >/dev/null || die "image link is invalid: $link"
  fi
}

prune_managed_images() {
  local newly_installed=$1
  local current_link="${install_dir}/neovim.sif"
  local previous_link="${install_dir}/neovim.previous.sif"
  local name path record
  local -a records=()
  declare -A retained=()

  if name=$(safe_link_target "$current_link"); then
    retained["$name"]=1
  fi
  if name=$(safe_link_target "$previous_link"); then
    retained["$name"]=1
  fi
  if (( ! activate )); then
    retained["$newly_installed"]=1
  fi

  shopt -s nullglob
  for path in "${install_dir}"/neovim_*_g*_*_*.sif; do
    name=${path##*/}
    is_managed_name "$name" || continue
    records+=("$(stat -c '%Y' -- "$path")|$name")
  done
  shopt -u nullglob

  if ((${#records[@]})); then
    mapfile -t records < <(printf '%s\n' "${records[@]}" | sort -rn)
  fi

  for record in "${records[@]}"; do
    name=${record#*|}
    [[ -n ${retained[$name]+x} ]] && continue
    if ((${#retained[@]} < keep)); then
      retained["$name"]=1
    fi
  done

  if ((${#retained[@]} > keep)); then
    log "Retention warning: ${#retained[@]} linked or newly installed images are protected (requested: $keep)."
  fi

  for record in "${records[@]}"; do
    name=${record#*|}
    [[ -n ${retained[$name]+x} ]] && continue
    log "Removing old managed image: ${install_dir}/$name"
    rm -f -- "${install_dir}/$name"
  done
}

rollback_images() {
  local current_link="${install_dir}/neovim.sif"
  local previous_link="${install_dir}/neovim.previous.sif"
  local current previous

  check_link_type "$current_link"
  check_link_type "$previous_link"
  current=$(safe_link_target "$current_link") || die "no valid current image to roll back"
  previous=$(safe_link_target "$previous_link") || die "no valid previous image to activate"

  if [[ $(mv --help 2>&1) != *--exchange* ]]; then
    die "atomic rollback requires mv with --exchange support"
  fi
  verify_image "${install_dir}/$previous"
  if (( dry_run )); then
    log "Would activate: ${install_dir}/$previous"
    log "Would retain as previous: ${install_dir}/$current"
    return
  fi

  mv --exchange -- "$current_link" "$previous_link"
  log "Activated: ${install_dir}/$previous"
  log "Previous: ${install_dir}/$current"
}

while (($#)); do
  case "$1" in
    --install-dir)
      (($# >= 2)) || die "--install-dir requires a path"
      install_dir=$2
      shift 2
      ;;
    --keep)
      (($# >= 2)) || die "--keep requires a number"
      keep=$2
      shift 2
      ;;
    --no-activate)
      activate=0
      shift
      ;;
    --force)
      force=1
      shift
      ;;
    --dry-run)
      dry_run=1
      shift
      ;;
    --rollback)
      rollback=1
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    --)
      shift
      (($# == 1)) || die "expected exactly one image"
      source_image=$1
      shift
      ;;
    -*) die "unknown option: $1" ;;
    *)
      [[ -z $source_image ]] || die "expected exactly one image"
      source_image=$1
      shift
      ;;
  esac
done

[[ $keep =~ ^[1-9][0-9]*$ ]] || die "--keep must be a positive integer"
if (( rollback )); then
  [[ -z $source_image ]] || die "--rollback does not accept an image"
  (( activate )) || die "--rollback cannot be combined with --no-activate"
  (( ! force )) || die "--rollback cannot be combined with --force"
else
  [[ -n $source_image ]] || die "an image is required"
fi

if (( dry_run )); then
  if [[ -d $install_dir ]]; then
    install_dir=$(cd -P -- "$install_dir" && pwd)
  else
    install_dir=$(realpath -m -- "$install_dir")
  fi
else
  mkdir -p -- "$install_dir"
  install_dir=$(cd -P -- "$install_dir" && pwd)
fi

if (( rollback )); then
  [[ -d $install_dir ]] || die "container directory does not exist: $install_dir"
  if (( ! dry_run )); then
    exec 9>"${install_dir}/.install_nvim_container.lock"
    flock -x 9
  fi
  rollback_images
  exit 0
fi

[[ -f $source_image ]] || die "image does not exist: $source_image"
source_image=$(realpath -- "$source_image")
artifact_name=${source_image##*/}
raw_image=0
if [[ $artifact_name =~ ^neovim_([0-9]+\.[0-9]+\.[0-9]+)_g([0-9a-fA-F]{7,40})_([0-9a-fA-F]{8,64})_(x86|x86_64|aarch64|ppc64le)\.sif$ ]]; then
  expected_version=${BASH_REMATCH[1]}
  name_digest=${BASH_REMATCH[3],,}
  image_arch=$(normalize_arch "${BASH_REMATCH[4]}")
elif [[ $artifact_name =~ ^nvim_container_(x86|aarch64|ppc64le)\.sif$ ]]; then
  raw_image=1
  image_arch=$(normalize_arch "${BASH_REMATCH[1]}")
else
  die "invalid image name: $artifact_name"
fi
host_arch=$(normalize_arch "$(uname -m)")
[[ $image_arch == "$host_arch" ]] || die "image architecture $image_arch does not match host architecture $host_arch"

source_digest=$(sha256sum -- "$source_image")
source_digest=${source_digest%% *}
if (( ! raw_image )); then
  [[ $source_digest == "$name_digest"* ]] || die "filename digest does not match image SHA-256"
fi

checksum_file="${source_image}.sha256"
if [[ -f $checksum_file ]]; then
  expected_digest=
  read -r expected_digest _ <"$checksum_file" || [[ -n $expected_digest ]] || die "cannot read checksum: $checksum_file"
  expected_digest=${expected_digest,,}
  [[ $expected_digest =~ ^[0-9a-f]{64}$ ]] || die "invalid checksum file: $checksum_file"
  [[ $source_digest == "$expected_digest" ]] || die "checksum verification failed: $source_image"
fi

if (( raw_image )); then
  image_dir=${source_image%/*}
  if ! revision=$(env -u GIT_DIR -u GIT_WORK_TREE -u GIT_COMMON_DIR -u GIT_OBJECT_DIRECTORY \
    -u GIT_ALTERNATE_OBJECT_DIRECTORIES -u GIT_INDEX_FILE -u GIT_NAMESPACE \
    git -C "$image_dir" rev-parse --verify 'HEAD^{commit}' 2>/dev/null); then
    die "cannot determine repository revision for raw build image: $source_image"
  fi
  revision=${revision,,}
  [[ $revision =~ ^[0-9a-f]{7,40}$ ]] || die "invalid repository revision for raw build image: $revision"
  expected_version=$(image_version "$source_image")
  [[ $expected_version =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || die "image reports unsupported Neovim version: NVIM v${expected_version}"
  artifact_name="neovim_${expected_version}_g${revision}_${source_digest}_${image_arch}.sif"
else
  verify_image "$source_image" "$expected_version"
fi
destination="${install_dir}/$artifact_name"

if (( dry_run )); then
  if [[ -d $install_dir ]]; then
    check_link_type "${install_dir}/neovim.sif"
    check_link_type "${install_dir}/neovim.previous.sif"
    check_link_target "${install_dir}/neovim.sif"
    check_link_target "${install_dir}/neovim.previous.sif"
  fi
  [[ ! -L $destination ]] || die "refusing to replace artifact symlink: $destination"
  [[ ! -e $destination || -f $destination ]] || die "refusing to replace non-regular artifact: $destination"
  if [[ -f $destination ]]; then
    destination_digest=$(sha256sum -- "$destination")
    destination_digest=${destination_digest%% *}
    if [[ $destination_digest != "$source_digest" ]] && (( ! force )); then
      die "destination exists with different content; use --force to replace it"
    fi
  fi
  log "Validated: $source_image"
  log "Would install: $destination"
  if (( activate )); then
    log "Would activate: $destination"
  fi
  log "Would retain up to $keep managed images, excluding additional protected links."
  exit 0
fi

exec 9>"${install_dir}/.install_nvim_container.lock"
flock -x 9
check_link_type "${install_dir}/neovim.sif"
check_link_type "${install_dir}/neovim.previous.sif"
check_link_target "${install_dir}/neovim.sif"
check_link_target "${install_dir}/neovim.previous.sif"

copy_image=1
[[ ! -L $destination ]] || die "refusing to replace artifact symlink: $destination"
[[ ! -e $destination || -f $destination ]] || die "refusing to replace non-regular artifact: $destination"
if [[ -f $destination ]]; then
  destination_digest=$(sha256sum -- "$destination")
  destination_digest=${destination_digest%% *}
  if [[ $destination_digest == "$source_digest" ]]; then
    copy_image=0
  elif (( ! force )); then
    die "destination exists with different content; use --force to replace it"
  fi
fi

if (( copy_image )); then
  stage=$(mktemp "${install_dir}/.${artifact_name}.XXXXXX")
  cp --reflink=auto -- "$source_image" "$stage"
  chmod 0755 -- "$stage"
  copied_digest=$(sha256sum -- "$stage")
  copied_digest=${copied_digest%% *}
  [[ $copied_digest == "$source_digest" ]] || die "copied image checksum does not match source"
  verify_image "$stage" "$expected_version"
  sync -f "$stage"
  mv -fT -- "$stage" "$destination"
  stage=
  log "Installed: $destination"
else
  verify_image "$destination" "$expected_version"
  log "Already installed: $destination"
fi

if (( activate )); then
  current_link="${install_dir}/neovim.sif"
  previous_link="${install_dir}/neovim.previous.sif"
  old_current=
  if [[ -L $current_link ]]; then
    old_current=$(safe_link_target "$current_link") || die "current image link is invalid: $current_link"
  fi

  if [[ -n $old_current && $old_current != "$artifact_name" ]]; then
    replace_link "$old_current" "$previous_link"
  fi
  replace_link "$artifact_name" "$current_link"

  if (( keep == 1 )) && [[ -L $previous_link ]]; then
    rm -f -- "$previous_link"
  fi
  log "Activated: $destination"
  if [[ -L $previous_link ]]; then
    previous_name=$(safe_link_target "$previous_link") || die "previous image link is invalid: $previous_link"
    log "Previous: ${install_dir}/$previous_name"
  fi
fi

prune_managed_images "$artifact_name"
