Bootstrap: docker-archive
From: nvim_container_x86.tar

%environment
    export CC=clang
    export MKCHAD_NVIM_IMAGE=1

    # MkChad appends the same Node platform/architecture/major key used by the
    # shell and server bootstrap to this architecture-neutral mounted parent.
    if [ -n "${MSK_NPM_GLOBAL_BASE:-}" ]; then
        export MSK_NPM_GLOBAL_ROOT="${MSK_NPM_GLOBAL_BASE}"
    fi

%runscript
    # Run Neovim
    nvim "$@"
